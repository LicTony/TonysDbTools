<Window x:Class="TonysDbTools.Views.DetalleSpView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="{Binding Titulo}" 
        Width="900" 
        Height="700" 
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.ExtendViewIntoTitleBar="True">
    
    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleSearchCommand}" />
        <KeyBinding Key="F3" Command="{Binding BuscarSiguienteCommand}" />
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabecera -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Glyph="&#xE943;" 
                             FontSize="24" 
                             Foreground="{ui:ThemeResource SystemControlHighlightAccentBrush}" />
                <TextBlock Text="{Binding SpName}" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           Margin="12,0,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" 
                       FontStyle="Italic" 
                       Opacity="0.7" 
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Panel de Búsqueda (Ctrl + B) -->
        <Border Grid.Row="1" 
                Visibility="{Binding IsSearchOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{ui:ThemeResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="4" 
                Padding="8" 
                Margin="0,0,0,8"
                BorderBrush="{ui:ThemeResource SystemControlHighlightAccentBrush}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="TxtSearch" 
                         Width="250" 
                         Text="{Binding TextoBusquedaLocal, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding BuscarSiguienteCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Siguiente (F3)" 
                        Margin="8,0,0,0" 
                        Command="{Binding BuscarSiguienteCommand}" />
                <TextBlock Text="{Binding SearchStatus}" 
                           VerticalAlignment="Center" 
                           Margin="12,0,0,0" 
                           Foreground="{ui:ThemeResource SystemControlHighlightAccentBrush}" />
                <Button Content="X" 
                        Margin="20,0,0,0" 
                        Padding="8,0,8,0"
                        Command="{Binding ToggleSearchCommand}" 
                        Background="Transparent" 
                        BorderThickness="0" />
            </StackPanel>
        </Border>

        <!-- Contenido SQL -->
        <Border Grid.Row="2" 
                CornerRadius="8" 
                Background="{ui:ThemeResource SystemControlBackgroundAltHighBrush}"
                Padding="8">
            <Grid>
                <TextBox x:Name="SqlEditor"
                         Text="{Binding ContenidoSql}" 
                         IsReadOnly="True" 
                         AcceptsReturn="True" 
                         AcceptsTab="True"
                         HorizontalScrollBarVisibility="Auto" 
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" 
                         FontSize="14"
                         BorderThickness="0"
                         Background="Transparent" />
                
                <ui:ProgressRing IsActive="{Binding IsLoading}" 
                                Width="50" Height="50"
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    Margin="0,16,0,0" 
                    HorizontalAlignment="Right">
            <TextBlock Text="Ctrl + B para Buscar" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,20,0" />
            <Button Content="Copiar Todo" 
                    Command="{Binding CopiarTodoCommand}" 
                    Padding="12,4,12,4" />
            <Button Content="Cerrar" 
                    IsCancel="True" 
                    Margin="8,0,0,0" 
                    Padding="12,4,12,4" 
                    Click="Cerrar_Click" />
        </StackPanel>
    </Grid>
</Window>
