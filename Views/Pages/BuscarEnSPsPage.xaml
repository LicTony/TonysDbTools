<UserControl x:Class="TonysDbTools.Views.Pages.BuscarEnSPsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="32,28,32,16">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon FontSize="28"
                             Foreground="{ui:ThemeResource SystemControlHighlightAccentBrush}"
                             Glyph="&#xE943;" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold"
                           
                           Text="{Binding Titulo}" />
            </StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Opacity="0.65"
                       Text="{Binding Descripcion}" />
        </StackPanel>
        <Border Grid.Row="1"
                Margin="32,0,32,32"
                Padding="24"
                CornerRadius="8"
                >
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                <ui:FontIcon FontSize="48" Glyph="&#xE943;" />
                <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center" Text="En desarrollo..." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
