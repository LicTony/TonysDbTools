<UserControl x:Class="TonysDbTools.Views.Pages.BuscarEnSPsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Encabezado  -->
        <StackPanel Grid.Row="0" Margin="32,24,32,16">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon FontSize="28"
                             Foreground="{ui:ThemeResource SystemControlHighlightAccentBrush}"
                             Glyph="&#xE943;" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="{Binding Titulo}" />
            </StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Opacity="0.65"
                       Text="{Binding Descripcion}" />
        </StackPanel>

        <!--  Filtros de Búsqueda  -->
        <Border Grid.Row="1"
                Margin="32,0,32,16"
                Padding="20"
                Background="{ui:ThemeResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="8">
            <StackPanel>
                <WrapPanel VerticalAlignment="Bottom">
                    <StackPanel Width="220" Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4" Text="Conexión SQL Server" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  DisplayMemberPath="Detalle"
                                  ItemsSource="{Binding Conexiones}"
                                  SelectedItem="{Binding ConexionSeleccionada}" />
                    </StackPanel>

                    <StackPanel Width="200" Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4" Text="Filtro nombre SP" />
                        <TextBox Text="{Binding FiltroSp, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Width="250" Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4" Text="Texto a buscar" />
                        <TextBox Text="{Binding TextoBuscar, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,8" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Width="100"
                                    Command="{Binding BuscarCommand}"
                                    Content="Buscar" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding LimpiarCommand}"
                                    Content="Limpiar" />
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>

                <TextBlock Margin="0,8,0,0"
                           FontStyle="Italic"
                           Opacity="0.8"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>

        <!--  Resultados  -->
        <Border Grid.Row="2"
                Margin="32,0,32,8"
                Background="{ui:ThemeResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="8">
            <Grid>
                <DataGrid AutoGenerateColumns="False"
                          Background="Transparent"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          ItemsSource="{Binding Resultados}"
                          IsReadOnly="True">
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" 
                                      Command="{Binding VerDetalleSpCommand}" 
                                      CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*"
                                            Binding="{Binding Store}"
                                            Header="Store (Doble clic para ver código)">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="Doble clic para ver el código fuente del store" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="150"
                                            Binding="{Binding CantOcurrencias}"
                                            Header="Cant. Ocurrencias" />
                    </DataGrid.Columns>
                </DataGrid>
                
                <!--  Indicador de carga  -->
                <ui:ProgressRing IsActive="{Binding IsSearching}" 
                                Width="48" Height="48"
                                VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <!--  Footer / Resultados encontrados  -->
        <TextBlock Grid.Row="3"
                   Margin="32,0,32,16"
                   FontWeight="SemiBold"
                   Opacity="0.7"
                   Text="{Binding ResultCountMessage}" />
    </Grid>
</UserControl>
