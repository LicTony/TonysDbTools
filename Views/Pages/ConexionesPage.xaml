<UserControl x:Class="TonysDbTools.Views.Pages.ConexionesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
             xmlns:models="clr-namespace:TonysDbTools.Models">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Encabezado  -->
        <StackPanel Grid.Row="0" Margin="32,24,32,16">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon FontSize="28"
                             Foreground="{ui:ThemeResource SystemControlHighlightAccentBrush}"
                             Glyph="&#xE968;" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="{Binding Titulo}" />
            </StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Opacity="0.65"
                       Text="{Binding Descripcion}" />
        </StackPanel>

        <!--  Formulario de CRUD  -->
        <Border Grid.Row="1"
                Margin="32,0,32,16"
                Padding="20"
                Background="{ui:ThemeResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Margin="0,0,0,12"
                           FontWeight="SemiBold"
                           Text="Nueva / Editar Conexión" />

                <WrapPanel Margin="0,0,0,12">
                    <StackPanel Width="200" Margin="0,0,12,0">
                        <TextBlock Margin="0,0,0,4" Text="Detalle / Nombre" />
                        <TextBox Text="{Binding Detalle, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,0">
                        <TextBlock Margin="0,0,0,4" Text="Tipo" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding TiposConexion}"
                                  SelectedItem="{Binding TipoSeleccionado}" />
                    </StackPanel>
                </WrapPanel>

                <!--  Campos dinámicos según el tipo  -->
                <Grid Margin="0,0,0,16">
                    <!--  Tipo UserPass  -->
                    <StackPanel x:Name="FieldsUserPass">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TipoSeleccionado}" Value="{x:Static models:TipoConexion.UserPass}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <WrapPanel>
                            <StackPanel Width="200" Margin="0,0,12,8">
                                <TextBlock Margin="0,0,0,4" Text="Servidor" />
                                <TextBox Text="{Binding Server}" />
                            </StackPanel>
                            <StackPanel Width="200" Margin="0,0,12,8">
                                <TextBlock Margin="0,0,0,4" Text="Base de Datos" />
                                <TextBox Text="{Binding BaseDeDatos}" />
                            </StackPanel>
                            <StackPanel Width="150" Margin="0,0,12,8">
                                <TextBlock Margin="0,0,0,4" Text="Usuario" />
                                <TextBox Text="{Binding Usuario}" />
                            </StackPanel>
                            <StackPanel Width="150" Margin="0,0,12,8">
                                <TextBlock Margin="0,0,0,4" Text="Contraseña" />
                                <PasswordBox x:Name="PassBox" PasswordChanged="PasswordBox_PasswordChanged" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <!--  Tipo Integrated Security  -->
                    <StackPanel x:Name="FieldsIntegrated">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TipoSeleccionado}" Value="{x:Static models:TipoConexion.IntegratedSecurity}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <WrapPanel>
                            <StackPanel Width="200" Margin="0,0,12,8">
                                <TextBlock Margin="0,0,0,4" Text="Servidor" />
                                <TextBox Text="{Binding Server}" />
                            </StackPanel>
                            <StackPanel Width="200" Margin="0,0,12,8">
                                <TextBlock Margin="0,0,0,4" Text="Base de Datos" />
                                <TextBox Text="{Binding BaseDeDatos}" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <!--  Tipo Connection String  -->
                    <StackPanel x:Name="FieldsConnString">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TipoSeleccionado}" Value="{x:Static models:TipoConexion.ConnectionString}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Margin="0,0,0,4" Text="Cadena de Conexión Completa" />
                        <TextBox Text="{Binding ConnectionString}" />
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding GuardarConexionCommand}"
                            Content="Guardar" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding ProbarConexionCommand}"
                            Content="Probar Conexión" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding LimpiarFormularioCommand}"
                            Content="Cancelar" />
                </StackPanel>

                <TextBlock Margin="0,12,0,0"
                           FontStyle="Italic"
                           Opacity="0.8"
                           Text="{Binding StatusMessage}" />
                </StackPanel>
                </Border>

        <!--  Listado de Conexiones  -->
        <Border Grid.Row="2"
                Margin="32,0,32,32"
                Background="{ui:ThemeResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="8">
            <DataGrid AutoGenerateColumns="False"
                      Background="Transparent"
                      BorderThickness="0"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      ItemsSource="{Binding Conexiones}"
                      SelectedItem="{Binding ConexionSeleccionada}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="Auto"
                                        Binding="{Binding Id}"
                                        Header="ID" />
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding Detalle}"
                                        Header="Detalle" />
                    <DataGridTextColumn Width="150"
                                        Binding="{Binding Tipo}"
                                        Header="Tipo" />
                    <DataGridTemplateColumn Width="100" Header="Acciones">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Padding="4"
                                            Command="{Binding DataContext.EditarConexionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            >
                                        <ui:FontIcon FontSize="12" Glyph="&#xE70F;" />
                                    </Button>
                                    <Button Margin="4,0,0,0"
                                            Padding="4"
                                            Command="{Binding DataContext.EliminarConexionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            >
                                        <ui:FontIcon FontSize="12" Glyph="&#xE74D;" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
