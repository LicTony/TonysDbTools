<UserControl x:Class="TonysDbTools.Views.Pages.Rel2TablasPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:TonysDbTools.ViewModels.Pages"
             xmlns:converters="clr-namespace:TonysDbTools.Converters"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:Rel2TablasViewModel}">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabecera -->
        <StackPanel Grid.Row="0" Margin="32,28,32,16">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon FontSize="28"
                             Foreground="{ui:ThemeResource SystemControlHighlightAccentBrush}"
                             Glyph="&#xE71D;" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="{Binding Titulo}" />
            </StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Opacity="0.65"
                       Text="{Binding Descripcion}" />
        </StackPanel>

        <!-- Filtros y Selección -->
        <StackPanel Grid.Row="1" Margin="32,0,32,16" Orientation="Horizontal">
            
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Tabla 1" Opacity="0.7" FontSize="12" Margin="0,0,0,4"/>
                <ui:AutoSuggestBox x:Name="AutoSuggestBox1"
                                   Width="220"
                                   PlaceholderText="Ej: Person.Person"
                                   Text="{Binding Tabla1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   ItemsSource="{Binding SugerenciasTabla1}"
                                   TextChanged="AutoSuggestBox1_TextChanged"
                                   Loaded="AutoSuggestBox_Loaded"
                                   QueryIcon="Find" />
            </StackPanel>

            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Tabla 2" Opacity="0.7" FontSize="12" Margin="0,0,0,4"/>
                <ui:AutoSuggestBox x:Name="AutoSuggestBox2"
                                   Width="220"
                                   PlaceholderText="Ej: Sales.SalesOrderHeader"
                                   Text="{Binding Tabla2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   ItemsSource="{Binding SugerenciasTabla2}"
                                   TextChanged="AutoSuggestBox2_TextChanged"
                                   Loaded="AutoSuggestBox_Loaded"
                                   QueryIcon="Find" />
            </StackPanel>

            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Profundidad" Opacity="0.7" FontSize="12" Margin="0,0,0,4"/>
                <ui:NumberBox Width="100" 
                              Value="{Binding MaxDepth, Mode=TwoWay}" 
                              Minimum="1" 
                              Maximum="10" 
                              SpinButtonPlacementMode="Inline" />
            </StackPanel>

            <CheckBox Margin="0,18,12,0" 
                      Content="Campo implícito" 
                      IsChecked="{Binding IncluirCamposImplicitos}" />

            <Button Margin="0,18,0,0"
                    Padding="16,6"
                    Command="{Binding BuscarRelacionesCommand}"
                    Content="Buscar Relaciones"
                    Style="{ui:StaticResource AccentButtonStyle}" />
        </StackPanel>

        <!-- Resultados -->
        <Grid Grid.Row="2" Margin="32,0,32,16">
            <Border BorderBrush="{ui:ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                
                <Grid>
                    <!-- Estado vacío o cargando -->
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center" 
                                Visibility="{Binding Resultado, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                        <ui:FontIcon FontSize="48" Glyph="&#xE71D;" Opacity="0.2" />
                        <TextBlock Margin="0,12,0,0" 
                                   HorizontalAlignment="Center" 
                                   Opacity="0.5"
                                   Text="Seleccione dos tablas y presione Buscar para ver sus relaciones." 
                                   Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        
                        <ui:ProgressRing IsActive="True" Margin="0,12,0,0" Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!-- Lista de resultados -->
                    <ListView ItemsSource="{Binding Resultado.Paths}"
                              Padding="8"
                              Visibility="{Binding Resultado, Converter={StaticResource NullToVisibilityConverter}}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="0,4" HorizontalContentAlignment="Stretch">
                                    <Expander.Header>
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:FontIcon Glyph="&#xE815;" Opacity="0.7" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                                <Run FontWeight="Bold" Text="{Binding Depth, Mode=OneWay, StringFormat='{}Pasos: {0}'}" />
                                                <Run Text=" - Camino de JOIN" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" 
                                                       Opacity="0.6" 
                                                       VerticalAlignment="Center" 
                                                       Visibility="{Binding IsDirect, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Run Text="Directo" />
                                            </TextBlock>
                                        </Grid>
                                    </Expander.Header>
                                    
                                    <Border Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Cadenas de JOIN:" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,8" />
                                            <ItemsControl ItemsSource="{Binding Steps}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ui:FontIcon Glyph="&#xE94A;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                            <TextBlock Grid.Column="1" TextWrapping="Wrap">
                                                                <Run FontWeight="SemiBold" Text="{Binding FromTable}" />
                                                                <Run Text="." />
                                                                <Run Text="{Binding FromColumn}" />
                                                                <Run Text=" ➔ " />
                                                                <Run FontWeight="SemiBold" Text="{Binding ToTable}" />
                                                                <Run Text="." />
                                                                <Run Text="{Binding ToColumn}" />
                                                                <Run Text="{Binding ConstraintName, StringFormat=' ({0})'}" />
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Margin="0,8,0,0" Text="SQL sugerido:" FontWeight="SemiBold" Opacity="0.8" />
                                            <Border Background="{ui:ThemeResource SystemControlBackgroundChromeMediumLowBrush}" 
                                                    Padding="8" CornerRadius="4">
                                                <TextBox FontFamily="Consolas" 
                                                         IsReadOnly="True" 
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         TextWrapping="NoWrap"
                                                         AcceptsReturn="True"
                                                         Text="{Binding Sql, Mode=OneWay}" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Expander>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Barra de estado -->
        <Border Grid.Row="3" Background="{ui:ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.8" FontSize="12" />
        </Border>
    </Grid>
</UserControl>
